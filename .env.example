# PostgreSQL
DATABASE_URL=postgresql://luvara:luvara_dev@localhost:5432/luvara

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development

# Stripe (Payment Service)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Storage
STORAGE_BUCKET=luvara-uploads

# Admin
ADMIN_API_KEY=change-this-to-a-secure-admin-api-key

# Ports
AUTH_PORT=4001
PROFILE_PORT=4001
DISCOVERY_PORT=4002
MATCH_PORT=4003
CHAT_PORT=4004
NOTIFICATION_PORT=4005
PAYMENT_PORT=4006
GAMIFICATION_PORT=4008
MODERATION_PORT=4009
ADMIN_PORT=4010

# Discovery
DECK_SIZE=50
DAILY_PICKS_SIZE=10
MATCH_WINDOW_HOURS=48

# Chat
MESSAGE_RATE_LIMIT=50
MESSAGE_RATE_WINDOW_MS=300000
