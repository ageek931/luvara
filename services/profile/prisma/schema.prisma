generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModerationStatus {
  pending
  approved
  rejected
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  displayName  String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles    Profile[]
  photos      Photo[]
  prompts     Prompt[]
  voiceIntros VoiceIntro[]
  videoIntros VideoIntro[]
  preferences UserPreference?

  @@index([email])
}

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  birthday        DateTime? @db.Date
  gender          String?
  orientation     String?
  bio             String?  @db.Text
  intent          String?
  valuesTags      String[]
  interests       String[]
  height          Int?
  education       String?
  occupation      String?
  locationLat     Float?
  locationLng     Float?
  locationCity    String?
  locationCountry String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([locationCity])
  @@index([intent])
  @@index([gender])
}

model Photo {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  url              String
  thumbnailUrl     String
  order            Int              @default(0)
  isPrimary        Boolean          @default(false)
  moderationStatus ModerationStatus @default(pending)
  moderationNote   String?
  createdAt        DateTime         @default(now())

  @@index([userId])
  @@index([userId, isPrimary])
}

model Prompt {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptText   String
  responseText String   @db.Text
  category     String
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VoiceIntro {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url         String
  durationSecs Float?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model VideoIntro {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  durationSecs Float?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model UserPreference {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ageMin           Int      @default(18)
  ageMax           Int      @default(60)
  distanceMax      Int      @default(50)
  genderPreference String[]
  intentPreference String[]
  dealbreakers     Json?
  verifiedOnly     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
