generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrustTier {
  Bronze
  Silver
  Gold
  Platinum
  Diamond
}

enum AuthProvider {
  email
  google
  apple
  facebook
}

model User {
  id               String       @id @default(uuid()) @db.Uuid
  email            String       @unique
  phone            String?
  passwordHash     String?
  authProvider     AuthProvider @default(email)
  authProviderId   String?
  displayName      String
  birthday         DateTime?    @db.Date
  gender           String?
  orientation      String?
  bio              String?      @db.Text
  intent           String?
  valuesTags       String[]
  interests        String[]
  height           Int?
  education        String?
  occupation       String?
  locationLat      Float?
  locationLng      Float?
  locationCity     String?
  locationCountry  String?
  trustScore       Int          @default(0)
  trustTier        TrustTier    @default(Bronze)
  isVerifiedPhoto  Boolean      @default(false)
  isVerifiedId     Boolean      @default(false)
  isVerifiedLiveness Boolean    @default(false)
  completenessScore Int         @default(0)
  level            Int          @default(1)
  xpTotal          Int          @default(0)
  referralCode     String       @unique
  isActive         Boolean      @default(true)
  isBanned         Boolean      @default(false)
  deviceFingerprint String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  lastActiveAt     DateTime     @default(now())

  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([referralCode])
  @@index([locationCity])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}
